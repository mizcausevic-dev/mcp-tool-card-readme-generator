{
  "name": "mcp-tool-card-readme-generator",
  "version": "0.1.0",
  "description": "Generate a human-readable Markdown README from a single MCP Tool Card JSON document (per mcp-tool-card-spec v0.1). Renders identity, safety badges (side-effect class, PII, secrets, approval, reversibility), input schema, tested-with table, performance, cost, audit. Per-doc analog to mcp-server-readme-generator. Closes the per-doc readme-gen pattern across all 4 governance protocols.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizcausevic-dev/mcp-tool-card-readme-generator"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tool-card",
    "readme",
    "markdown",
    "documentation",
    "ai-governance",
    "kinetic-gain-suite",
    "typescript"
  ],
  "bin": {
    "mcp-tool-card-readme-generator": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx src/cli.ts fixtures/destructive-tenant-reset.json",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
